# Copy to `.env` on the server (do not commit real secrets).
PORT=5000
NODE_ENV=production

MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated origins allowed by CORS (no trailing slash). Must match the live site + dev origins.
CLIENT_URL=https://patliputravinfast.in,https://www.patliputravinfast.in,http://localhost:5173,http://localhost:8080

# --- SEO ---
# Canonical site URL used in sitemap.xml, robots.txt and JSON-LD (no trailing slash).
SITE_URL=https://patliputravinfast.in
# false = skip auto-creating the 38 districts x 4 models landing pages at startup.
SEO_AUTO_BOOTSTRAP=true

SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google reCAPTCHA v3 (optional). If unset, verification is skipped server-side.
# Pair with VITE_RECAPTCHA_SITE_KEY on the frontend.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# --- WhatsApp OTP (AiSensy) ---
# true = site-config exposes whatsappOtp; forms require POST verify token + DB challenge.
WHATSAPP_OTP_ENABLED=true
WHATSAPP_OTP_CODE_TTL_MS=600000
WHATSAPP_OTP_MAX_ATTEMPTS=5
WHATSAPP_OTP_RESEND_COOLDOWN_MS=60000
WHATSAPP_OTP_LOCK_MS=900000
WHATSAPP_OTP_TOKEN_EXPIRES_IN=15m

# Journey WhatsApp (non-OTP templates). Keep false until BSP campaign templates are ready.
WHATSAPP_JOURNEY_ENABLED=false
WHATSAPP_JOURNEY_USE_OTP_CAMPAIGN=false

# --- Official email notifications (VinFast / dealership SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Patliputra VinFast <noreply@patliputravinfast.com>"
VINFAST_EMAIL_FROM=
OPS_ESCALATION_EMAIL=

# Reverse geocoding: nominatim (default) or google
GEOCODING_PROVIDER=nominatim
GOOGLE_MAPS_API_KEY=
GEOCODING_USER_AGENT=PatliputraVinFastCRM/1.0

AISENSY_API_URL=https://backend.aisensy.com/campaign/t1/api/v2
AISENSY_API_KEY=
# Exact Live API campaign name from AiSensy (case-sensitive).
AISENSY_OTP_CAMPAIGN_NAME=otp
AISENSY_USER_NAME=Patliputra VinFast
AISENSY_SOURCE=website-form
# Critical: must match WhatsApp template variables for this campaign (fixes "Template params does not match").
# otp_only → send [OTP] | name_otp → [Name, OTP] | otp_name → [OTP, Name]
AISENSY_OTP_PARAM_LAYOUT=name_otp
# Legacy alias if PARAM_LAYOUT unset: two → name_otp | one → otp_only
AISENSY_OTP_TEMPLATE_MODE=two
AISENSY_DEFAULT_COUNTRY_CODE=IN
# E.164 + prefix (default). Set false if AiSensy expects 91… without +.
AISENSY_DESTINATION_USE_PLUS=true
# Set false if the API rejects paramsFallbackValue.FirstName (rare).
AISENSY_USE_PARAMS_FALLBACK_FIRSTNAME=true
# true = JSON error message includes AiSensy response text (debug only).
AISENSY_VERBOSE_ERRORS=false

# --- Meta Lead (public GET All_leads — no JWT) ---
# Your Meta / whitelisted leads API URL (this backend proxies it for the frontend).
META_LEADS_UPSTREAM_URL=
# Optional Bearer token for upstream (if Meta requires it).
META_LEADS_API_TOKEN=
META_LEADS_TIMEOUT_MS=25000
