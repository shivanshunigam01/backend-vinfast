PORT=5000
NODE_ENV=development
MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated, no trailing slash. Must match browser Origin exactly (http vs https, www vs bare).
CLIENT_URL=https://patliputravinfast.in,https://www.patliputravinfast.in,http://localhost:8080

SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin inbox alerts when visitors submit leads / test drives / enquiries (website forms).
# Comma-separated recipient addresses.
ADMIN_NOTIFY_EMAIL=shivanshunigam8@gmail.com   

# SMTP (use your provider: Gmail app password, Outlook, SendGrid, AWS SES, etc.)
SMTP_HOST=
SMTP_PORT=587
# Set to true for port 465 (SSL). Usually false for 587 (STARTTLS).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# From header seen by recipients — often must match your SMTP account domain.
MAIL_FROM=

# --- WhatsApp OTP (AiSensy) — require verification before public lead / TD / enquiry submits ---
# When true, frontend shows OTP step and POST /leads|test-drives|enquiries require whatsappVerificationToken.
WHATSAPP_OTP_ENABLED=false
# Code validity (stored hashed); default 10 minutes.
WHATSAPP_OTP_CODE_TTL_MS=600000
# JWT returned after successful verify — must cover form fill time.
WHATSAPP_OTP_TOKEN_EXPIRES_IN=15m

# AiSensy campaign API (same payload shape as dashboard API campaigns).
AISENSY_API_URL=https://backend.aisensy.com/campaign/t1/api/v2
AISENSY_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5YjgxMWVkODNiYjg3MjY3NGFmMmE3ZSIsIm5hbWUiOiJaZW50cm92ZXJzZSIsImFwcE5hbWUiOiJBaVNlbnN5IiwiY2xpZW50SWQiOiI2OWI4MTFlZDkwZjZjZjBlMDY0NzBkMTciLCJhY3RpdmVQbGFuIjoiTk9ORSIsImlhdCI6MTc3MzY3MDg5M30.wFOeDPo6S3cd2cRlhZ31r_zBS_lTLRgXS-FQuk9XFuc
AISENSY_OTP_CAMPAIGN_NAME=otp
# Display name shown in AiSensy user field / template — falls back to "Customer".
AISENSY_USER_NAME=Patliputra VinFast
# Optional label for analytics in AiSensy.
AISENSY_SOURCE=website-form
# two = template expects [FirstName, OTP] | one = [OTP] only (match your WhatsApp template variables).
AISENSY_OTP_TEMPLATE_MODE=two
