# Critical: must match WhatsApp template variables for this campaign (fixes "Template params does not match").
# otp_only → send [OTP] | name_otp → [Name, OTP] | otp_name → [OTP, Name]
AISENSY_OTP_PARAM_LAYOUT=otp_only
# Legacy alias if PARAM_LAYOUT unset: two → name_otp | one → otp_only
AISENSY_OTP_TEMPLATE_MODE=two
AISENSY_DEFAULT_COUNTRY_CODE=IN
# E.164 + prefix (default). Set false if AiSensy expects 91… without +.
AISENSY_DESTINATION_USE_PLUS=true
# Set false if the API rejects paramsFallbackValue.FirstName (rare).
AISENSY_USE_PARAMS_FALLBACK_FIRSTNAME=true
# true = JSON error message includes AiSensy response text (debug only).
AISENSY_VERBOSE_ERRORS=false
